{
  "name": "dota2-mcp",
  "version": "1.3.2",
  "description": "MCP server for Dota 2 custom game development — real-time console bridge, live API docs, game control and asset tooling via the Model Context Protocol.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dota2-mcp": "dist/index.js"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "dist/tools/**/*",
    "skills/**/*",
    "README.md",
    "CLAUDE.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dota2",
    "dota-2",
    "custom-game",
    "vconsole2",
    "console-bridge"
  ],
  "scripts": {
    "build": "npm run sync-version && tsc",
    "bundle": "esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs",
    "package": "npm run bundle && node scripts/sea-package.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "check": "tsc --noEmit && node scripts/sync-version.mjs --check",
    "sync-version": "node scripts/sync-version.mjs",
    "prepack": "npm run sync-version"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.3",
    "find-steam-app": "^1.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^18.19.100",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
