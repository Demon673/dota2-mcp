{
  "name": "dota2-mcp",
  "version": "1.0.0",
  "description": "MCP server for Dota 2 custom game development — real-time console bridge, live API docs, game control and asset tooling via the Model Context Protocol.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dota2-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dota2",
    "dota-2",
    "custom-game",
    "vconsole2",
    "console-bridge"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^18.19.100",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
